{
  "name": "@medhira/n8n-nodes-markdown-pdf",
  "version": "1.0.0",
  "description": "Convert Markdown to PDF inside n8n using Puppeteer - A Medhira community package",
  "keywords": [
    "n8n",
    "markdown",
    "pdf",
    "medhira"
  ],
  "license": "Apache-2.0",
  "author": "MEDHIRA <hello.medhira@gmail.com>",
  "main": "dist/index.js",
  "n8n": {
    "nodes": [
      "dist/nodes/MarkdownToPdf.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && copyfiles -u 2 \"nodes/**/*.svg\" dist/",
    "docs:build": "mkdocs build",
    "docs:serve": "mkdocs serve"
  },
  "dependencies": {
    "marked": "^18.0.2",
    "n8n-workflow": "^2.16.0",
    "puppeteer": "^24.42.0"
  },
  "devDependencies": {
    "copyfiles": "^2.4.1",
    "typescript": "^6.0.3",
    "mkdocs": "^1.6.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HELLOMEDHIRA/n8n-nodes-medhira"
  },
  "homepage": "https://medhira.readthedocs.io/en/latest/",
  "bugs": {
    "url": "https://github.com/HELLOMEDHIRA/n8n-nodes-medhira/issues"
  }
}